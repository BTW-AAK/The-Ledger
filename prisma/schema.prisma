generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  passwordHash      String
  homeCurrency      String   @default("USD")
  hasSeenOnboarding Boolean  @default(false)
  createdAt         DateTime @default(now())

  accounts            Account[]
  transactions        Transaction[]
  categories          Category[]
  budgets             Budget[]
  goals               Goal[]
  recurringTemplates  RecurringTemplate[]
  holdings            Holding[]
  currencyRates       CurrencyRate[]
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  LOAN
  CASH
  INVESTMENT
}

model Account {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  type            AccountType
  currency        String      @default("USD")
  // Stored in cents. For CREDIT_CARD/LOAN, positive startingBalance means money owed.
  startingBalance Int         @default(0)
  archived        Boolean     @default(false)
  createdAt       DateTime    @default(now())

  transactions       Transaction[]
  goals              Goal[]
  recurringTemplates RecurringTemplate[]
  holdings           Holding[]
}

enum CategoryKind {
  FIXED
  FLEXIBLE
  INCOME
}

model Category {
  id       String        @id @default(cuid())
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  kind     CategoryKind  @default(FLEXIBLE)
  icon     String        @default("ti-tag")
  color    String        @default("#8FA39A")
  parentId String?
  parent   Category?     @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[]    @relation("CategoryParent")

  transactions        Transaction[]
  budgets             Budget[]
  recurringTemplates  RecurringTemplate[]

  @@unique([userId, name])
}

model Transaction {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId  String
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  date       DateTime
  // Cents. Positive = income/credit, negative = expense/debit.
  amount     Int
  merchant   String
  notes      String?
  tags       String[]  @default([])
  receiptUrl String?
  createdAt  DateTime  @default(now())

  @@index([userId, date])
  @@index([userId, accountId])
  @@index([userId, categoryId])
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  // "YYYY-MM"
  month      String
  amount     Int
  rollover   Boolean  @default(false)

  @@unique([categoryId, month])
}

model Goal {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  targetAmount    Int
  targetDate      DateTime?
  currentAmount   Int       @default(0)
  linkedAccountId String?
  linkedAccount   Account?  @relation(fields: [linkedAccountId], references: [id])
  createdAt       DateTime  @default(now())
}

enum Cadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

model RecurringTemplate {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  merchant    String?
  amount      Int
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cadence     Cadence
  nextDueDate DateTime
  active      Boolean   @default(true)
}

model Holding {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name         String
  ticker       String?
  quantity     Float
  costBasis    Int
  currentValue Int
  updatedAt    DateTime @updatedAt
}

/// How many units of the user's home currency one unit of `currency` is worth.
/// e.g. if home currency is USD and currency is "EUR" with rateToHome 1.08,
/// that means 1 EUR = 1.08 USD. The home currency itself is never stored here (implicit rate of 1).
model CurrencyRate {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency   String
  rateToHome Float
  updatedAt  DateTime @updatedAt

  @@unique([userId, currency])
}
