# PostgreSQL connection string. When using Neon/Supabase, copy their connection string here.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"

# The URL your app runs at. http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"

# Used only by `npm run seed` to create your login.
SEED_USER_EMAIL="you@example.com"
SEED_USER_PASSWORD="choose-a-real-password"

# Optional: gate self-signup behind a shared code. Anyone with this code can create
# their own account at /signup. Leave unset to allow open signup to anyone with the URL.
SIGNUP_CODE="pick-something-only-you-and-your-friends-know"
